---
import Main from '../layouts/Main.astro';
import ContactCards from '../components/ContactCards.astro';
---

<Main title="Welcome">
  <!-- Hero Section -->
  <section class="hero-section">
    <div class="hero-glow"></div>
    <div class="hero-inner">
      <div class="hero-content">
        <div class="hero-photo fade-in">
          <img src="/images/about/garden-color.jpg" alt="Donovan Jasper" />
        </div>
        <div class="hero-text">
          <h1 class="fade-in">Howdy!</h1>
          <p class="hero-bio fade-in">
            I'm <strong>Donovan Jasper</strong>. I currently work as an engineer at <span class="accent">Numenor AI</span>. I'm also a coterm at Stanford University pursuing a BSH in Computer Science, a BAH in Music, and an MEng in Computer Science with a concentration in Network and Computer Security.
          </p>
          <p class="hero-sub fade-in">
            My interests span the technical and creative spectrum with concentrations in cybersecurity and performance.
          </p>
          <div class="hero-links fade-in">
            <a href="/portfolio/" class="hero-btn">Portfolio</a>
            <a href="/tech/cybersecurity/research/artemis/" class="hero-btn-ghost">ARTEMIS Research</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Cybersecurity Section -->
  <section class="content-section">
    <div class="content-inner">
      <div class="split-section fade-in">
        <div class="split-text">
          <h2><span class="accent">//</span> Cybersecurity</h2>
          <p>
            I have several years of hands-on cybersecurity experience from freelancing and bug hunting on everything from open-source projects to large corporate Active Directory infrastructures. I've worked at OpenAI, Formal, Black Hills Information Security, and CrowdStrike, and I serve as the competitions lead for Stanford Applied Cyber.
          </p>
          <p>
            My recent research on AI agents in penetration testing (ARTEMIS) was <a href="https://www.wsj.com/tech/ai/ai-hackers-are-coming-dangerously-close-to-beating-humans-4afc3ad6" target="_blank" rel="noopener noreferrer">featured in the Wall Street Journal</a>.
          </p>
        </div>
        <div class="split-photo">
          <img src="/images/about/tokyo-harbor.jpg" alt="Donovan in Tokyo" />
        </div>
      </div>
      <div class="photo-wide fade-in">
        <img src="/images/about/nccdc2023.jpg" alt="NCCDC Team" />
        <span class="photo-caption">National Champions — Collegiate Cyber Defense Competition, 2023</span>
      </div>
    </div>
  </section>

  <!-- Arts Section -->
  <section class="content-section alt-bg">
    <div class="content-inner">
      <div class="split-section reverse fade-in">
        <div class="split-text">
          <h2><span class="accent">//</span> Arts & Performance</h2>
          <p>
            On the artistic front, I'm a trained vocalist, dancer, and performer. I am actively involved in performing and managing Stanford's music scene.
          </p>
        </div>
        <div class="split-photo">
          <img src="/images/about/donovanface.jpeg" alt="Donovan Jasper" />
        </div>
      </div>
      <div class="photo-grid fade-in">
        <div class="photo-item">
          <img src="/images/about/ballet2.png" alt="Ballet" />
          <span class="photo-caption">Grand Pas de Deux — The Nutcracker</span>
        </div>
        <div class="photo-item">
          <img src="/images/about/singing2.png" alt="Singing" />
          <span class="photo-caption">Vocal Performance — Stanford</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Connect -->
  <section class="content-section">
    <div class="content-inner fade-in">
      <p class="closing">
        I do my best work when the (computer) chips are down and thrive in challenging environments, whether collaborating to defend against active cyber threats or performing on stage. I'm always excited to connect with new people and explore innovative ideas — please don't hesitate to say hello!
      </p>
      <h2><span class="accent">//</span> Connect</h2>
      <ContactCards />
    </div>
  </section>
</Main>

<style>
  /* Hero */
  .hero-section {
    position: relative;
    overflow: hidden;
    background: var(--gradient-hero);
  }
  .hero-glow {
    position: absolute;
    top: -20%;
    right: -10%;
    width: 40rem;
    height: 40rem;
    border-radius: 50%;
    background: var(--accent);
    opacity: 0.03;
    filter: blur(80px);
    pointer-events: none;
  }
  .hero-inner {
    position: relative;
    max-width: 64rem;
    margin: 0 auto;
    padding: 5rem 2rem 4rem;
  }
  .hero-content {
    display: flex;
    align-items: center;
    gap: 3rem;
  }
  .hero-text {
    flex: 1;
  }
  .hero-greeting {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--accent);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }
  .hero-text h1 {
    font-family: var(--font-heading);
    font-size: 2.25rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    margin-bottom: 1rem;
    color: var(--text-primary);
  }
  .hero-bio {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--text-secondary);
    margin-bottom: 0.5rem;
  }
  .hero-sub {
    font-size: 0.9rem;
    line-height: 1.7;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }
  .hero-links {
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }
  .hero-btn {
    display: inline-block;
    padding: 0.5rem 1.25rem;
    border-radius: 8px;
    font-size: 0.85rem;
    font-weight: 600;
    font-family: var(--font-heading);
    background: var(--accent);
    color: white;
    text-decoration: none;
    transition: all 0.2s ease;
  }
  .hero-btn:hover {
    opacity: 0.9;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(129, 140, 248, 0.3);
    color: white;
  }
  .hero-btn-ghost {
    display: inline-block;
    padding: 0.5rem 1.25rem;
    border-radius: 8px;
    font-size: 0.85rem;
    font-weight: 600;
    font-family: var(--font-heading);
    border: 1px solid var(--border);
    color: var(--text-secondary);
    text-decoration: none;
    transition: all 0.2s ease;
  }
  .hero-btn-ghost:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: var(--accent-muted);
  }
  .hero-photo {
    flex-shrink: 0;
  }
  .hero-photo {
    position: relative;
    z-index: 1;
  }
  .hero-photo img {
    width: 200px;
    border-radius: 12px;
    object-fit: cover;
    aspect-ratio: 3/4;
    box-shadow: 0 8px 30px rgba(0,0,0,0.15);
    border: 1px solid var(--border);
    transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.4s ease;
    cursor: pointer;
  }
  .hero-photo img:hover {
    transform: scale(1.35);
    box-shadow: 0 30px 80px rgba(0,0,0,0.35);
    z-index: 50;
    border-radius: 16px;
  }

  /* Content sections */
  .content-section {
    padding: 4rem 0;
  }
  .content-section.alt-bg {
    background: var(--bg-secondary);
  }
  .content-inner {
    max-width: 64rem;
    margin: 0 auto;
    padding: 0 2rem;
  }
  .content-inner h2 {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: var(--text-primary);
  }
  .content-inner p {
    font-size: 0.95rem;
    line-height: 1.75;
    color: var(--text-secondary);
    max-width: 48rem;
    margin-bottom: 1rem;
  }
  .content-inner a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1.5px;
  }
  .content-inner a:hover {
    color: var(--accent-hover);
  }
  .closing {
    margin-bottom: 2rem;
  }
  .accent {
    color: var(--accent);
  }

  /* Split section — text + photo side by side */
  .split-section {
    display: flex;
    align-items: center;
    gap: 2.5rem;
    margin-bottom: 2rem;
  }
  .split-section.reverse {
    flex-direction: row-reverse;
  }
  .split-text {
    flex: 1;
  }
  .split-text h2 {
    margin-bottom: 0.75rem;
  }
  .split-photo {
    flex-shrink: 0;
  }
  .split-photo {
    position: relative;
    z-index: 1;
  }
  .split-photo img {
    width: 180px;
    border-radius: 12px;
    object-fit: cover;
    aspect-ratio: 3/4;
    border: 1px solid var(--border);
    box-shadow: var(--shadow);
    transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.4s ease;
    cursor: pointer;
  }
  .split-photo img:hover {
    transform: scale(1.3);
    box-shadow: 0 24px 70px rgba(0,0,0,0.3);
    z-index: 50;
    border-radius: 16px;
  }

  /* Photos */
  .photo-wide {
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--border);
    box-shadow: var(--shadow);
    position: relative;
  }
  .photo-wide img {
    width: 100%;
    display: block;
    object-fit: cover;
    max-height: 380px;
    object-position: center 15%;
  }
  .photo-caption {
    display: block;
    padding: 0.6rem 1rem;
    font-size: 0.75rem;
    color: var(--text-muted);
    background: var(--bg-card);
    border-top: 1px solid var(--border);
  }
  .photo-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .photo-item {
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--border);
    box-shadow: var(--shadow);
    transition: transform 0.3s ease;
  }
  .photo-item {
    position: relative;
    z-index: 1;
  }
  .photo-item:hover {
    transform: scale(1.05);
    box-shadow: 0 16px 50px rgba(0,0,0,0.2);
    z-index: 50;
  }
  .photo-item img {
    width: 100%;
    display: block;
    object-fit: cover;
    aspect-ratio: 5/4;
    object-position: center top;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .hero-content {
      flex-direction: column;
      text-align: center;
    }
    .hero-links {
      justify-content: center;
    }
    .hero-photo img {
      width: 160px;
    }
    .split-section,
    .split-section.reverse {
      flex-direction: column;
    }
    .split-photo img {
      width: 140px;
    }
    .photo-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
