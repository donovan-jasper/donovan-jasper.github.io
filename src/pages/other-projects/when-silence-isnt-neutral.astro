---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
---

<Base title="When Silence Isn't Neutral">
  <Nav />
  <style>
    :root {
      --purple-dark: #5b4b8a;
      --purple-light: #7c6cb0;
      --purple-muted: #9589b8;
      --pink: #d64d6a;
      --pink-light: #e8a0ae;
      --coral: #e07566;
      --teal: #2a9d8f;
      --teal-light: #8cd3cb;
      --mint: #52c7b8;
      --orange: #e9a23b;
      --gold: #f4d35e;
      --gray-900: #1a1a2e;
      --gray-800: #2d2d44;
      --gray-700: #404055;
      --gray-600: #5a5a6e;
      --gray-500: #7a7a8c;
      --gray-400: #9e9eab;
      --gray-300: #c4c4ce;
      --gray-200: #e2e2e8;
      --gray-100: #f5f5f7;
      --bg-cream: #faf9f7;
      --wsin-white: #ffffff;
      --shadow-sm: 0 1px 2px rgba(0,0,0,0.04), 0 1px 3px rgba(0,0,0,0.06);
      --shadow-md: 0 4px 6px rgba(0,0,0,0.04), 0 2px 4px rgba(0,0,0,0.06);
      --shadow-lg: 0 10px 25px rgba(0,0,0,0.06), 0 4px 10px rgba(0,0,0,0.04);
      --shadow-xl: 0 20px 40px rgba(0,0,0,0.08), 0 8px 16px rgba(0,0,0,0.04);
      --radius-sm: 8px;
      --radius-md: 12px;
      --radius-lg: 16px;
      --radius-xl: 24px;
      --transition-fast: 0.15s ease;
      --transition-normal: 0.25s ease;
      --transition-slow: 0.4s ease;
    }

    .wsin-page {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      color: var(--gray-800);
      line-height: 1.75;
      font-size: 17px;
    }

    .wsin-page .cover {
      min-height: 80vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      text-align: center;
      padding: 3rem;
      background: linear-gradient(150deg, #5b4b8a 0%, #7c6cb0 25%, #8b5a7c 50%, #d64d6a 75%, #e07566 100%);
      position: relative;
      overflow: hidden;
    }

    .wsin-page .cover-content {
      position: relative;
      z-index: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .wsin-page .cover h1 {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: clamp(2.5rem, 8vw, 4.5rem);
      color: white;
      margin-bottom: 0.5rem;
      text-shadow: 0 4px 20px rgba(0,0,0,0.2);
    }

    .wsin-page .subtitle {
      font-size: 1.2rem;
      color: rgba(255,255,255,0.9);
      font-weight: 400;
      margin-bottom: 1.5rem;
    }

    .wsin-page .cover-meta {
      color: rgba(255,255,255,0.75);
      font-size: 0.9rem;
      max-width: 500px;
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 1.5rem;
      margin: 1.5rem auto 0;
    }

    .wsin-page .cover-meta-item {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .wsin-page .cover-meta-item svg {
      width: 16px;
      height: 16px;
      opacity: 0.8;
    }

    .wsin-page .container {
      max-width: 900px;
      margin: 0 auto;
      padding: 4rem 2rem;
    }

    .wsin-page section {
      margin-bottom: 5rem;
      text-align: center;
    }

    .wsin-page section p, .wsin-page section ul, .wsin-page section ol {
      text-align: left;
      max-width: 750px;
      margin-left: auto;
      margin-right: auto;
    }

    .wsin-page section p {
      margin-bottom: 1rem;
      color: var(--gray-700);
    }

    .wsin-page section ul, .wsin-page section ol {
      margin-bottom: 2rem;
    }

    .wsin-page section ul:not(.numbered-list):not(.response-list) {
      padding-left: 1.5rem;
    }

    .wsin-page section ul:not(.numbered-list):not(.response-list) li {
      margin-bottom: 0.75rem;
      color: var(--gray-700);
    }

    .wsin-page h2 {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 2.2rem;
      background: linear-gradient(135deg, var(--purple-dark), var(--pink));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: 2rem;
      padding-bottom: 0.75rem;
      border-bottom: 2px solid var(--gray-200);
      display: inline-block;
      position: relative;
    }

    .wsin-page h2::after {
      content: '';
      position: absolute;
      bottom: -2px;
      left: 0;
      width: 60px;
      height: 2px;
      background: linear-gradient(90deg, var(--purple-light), var(--pink));
    }

    .wsin-page h3 {
      font-size: 1.15rem;
      color: var(--gray-800);
      margin: 2.5rem auto 1.25rem;
      max-width: 750px;
      text-align: left;
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .wsin-page h3::before {
      content: '';
      width: 4px;
      height: 1em;
      background: linear-gradient(180deg, var(--purple-light), var(--purple-dark));
      border-radius: 2px;
      flex-shrink: 0;
    }

    .wsin-page .section-divider {
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 5rem auto 4rem;
      max-width: 300px;
    }

    .wsin-page .section-divider::before,
    .wsin-page .section-divider::after {
      content: '';
      flex: 1;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--gray-300), transparent);
    }

    .wsin-page .section-divider-icon {
      width: 44px;
      height: 44px;
      border-radius: 50%;
      background: var(--wsin-white);
      border: 2px solid var(--gray-200);
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 1.5rem;
      font-size: 1.1rem;
      box-shadow: var(--shadow-sm);
    }

    .wsin-page .audience-box {
      background: var(--wsin-white);
      border-radius: var(--radius-xl);
      padding: 2.5rem;
      margin: 0 auto 3rem;
      border: 1px solid var(--gray-200);
      border-left: 4px solid var(--purple-dark);
      max-width: 800px;
      box-shadow: var(--shadow-lg);
    }

    .wsin-page .audience-box h3 {
      margin-top: 0;
      max-width: none;
    }

    .wsin-page .audience-box p {
      max-width: none;
      text-align: left;
    }

    .wsin-page .concept-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 1.5rem;
      margin: 2rem auto;
      justify-items: center;
      max-width: 820px;
    }

    .wsin-page .concept-card {
      background: var(--wsin-white);
      border-radius: var(--radius-lg);
      padding: 2rem 1.5rem;
      text-align: center;
      box-shadow: var(--shadow-md);
      transition: transform 0.3s ease, box-shadow 0.3s ease;
      width: 100%;
      max-width: 260px;
      border: 1px solid var(--gray-200);
    }

    .wsin-page .concept-card:hover {
      transform: translateY(-6px);
      box-shadow: var(--shadow-xl);
    }

    .wsin-page .concept-card.censorship { border-top: 3px solid var(--purple-light); }
    .wsin-page .concept-card.propaganda { border-top: 3px solid var(--pink); }
    .wsin-page .concept-card.self-censor { border-top: 3px solid var(--purple-dark); }

    .wsin-page .concept-icon {
      font-size: 2.8rem;
      margin-bottom: 0.75rem;
      display: block;
    }

    .wsin-page .concept-card h4 {
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      margin-bottom: 0.75rem;
      font-weight: 700;
    }

    .wsin-page .concept-card.censorship h4 { color: var(--purple-light); }
    .wsin-page .concept-card.propaganda h4 { color: var(--pink); }
    .wsin-page .concept-card.self-censor h4 { color: var(--purple-dark); }

    .wsin-page .concept-card p {
      font-size: 0.95rem;
      color: var(--gray-600);
      margin: 0;
      line-height: 1.5;
    }

    .wsin-page .quote-block {
      background: var(--wsin-white);
      border-radius: var(--radius-lg);
      padding: 2.5rem;
      margin: 2.5rem auto;
      position: relative;
      border: 1px solid var(--gray-200);
      border-left: 4px solid;
      max-width: 750px;
      box-shadow: var(--shadow-md);
    }

    .wsin-page .quote-block.purple { border-left-color: var(--purple-dark); }
    .wsin-page .quote-block.pink { border-left-color: var(--pink); }
    .wsin-page .quote-block.teal { border-left-color: var(--teal); }

    .wsin-page .quote-text {
      font-family: 'Playfair Display', Georgia, serif;
      font-style: italic;
      font-size: 1.25rem;
      color: var(--gray-800);
      margin-bottom: 1rem;
      padding-left: 1.25rem;
      text-align: left;
      max-width: none;
      line-height: 1.6;
    }

    .wsin-page .quote-source {
      font-size: 0.9rem;
      color: var(--gray-500);
      padding-left: 1.25rem;
      text-align: left;
      font-weight: 500;
    }

    .wsin-page .quote-translation {
      background: var(--gray-100);
      border-radius: var(--radius-md);
      padding: 1.25rem 1.5rem;
      margin-top: 1.5rem;
      font-size: 0.95rem;
      text-align: left;
      max-width: none;
      border: 1px solid var(--gray-200);
      position: relative;
    }

    .wsin-page .quote-translation::before {
      content: 'In plain language';
      position: absolute;
      top: -0.6rem;
      left: 1rem;
      background: var(--gray-100);
      padding: 0 0.5rem;
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: var(--gray-500);
      font-weight: 600;
    }

    .wsin-page .callout {
      border-radius: var(--radius-lg);
      padding: 1.75rem;
      margin: 2rem auto;
      display: flex;
      align-items: center;
      gap: 1rem;
      max-width: 750px;
      border: 1px solid;
    }

    .wsin-page .callout.centered {
      justify-content: center;
      text-align: center;
    }

    .wsin-page .callout-icon {
      font-size: 1.5rem;
      flex-shrink: 0;
      width: 40px;
      height: 40px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: var(--radius-sm);
    }

    .wsin-page .callout.highlight {
      background: #fef8f8;
      border-color: rgba(214, 77, 106, 0.2);
    }

    .wsin-page .callout.example {
      background: #f5fbfa;
      border-color: rgba(42, 157, 143, 0.2);
    }

    .wsin-page .callout.warning {
      background: #fffcf5;
      border-color: rgba(233, 162, 59, 0.2);
    }

    .wsin-page .callout div {
      text-align: left;
      flex: 1;
    }

    .wsin-page .numbered-list {
      counter-reset: item;
      list-style: none;
      padding: 0;
      max-width: 750px;
      margin: 1.5rem auto;
    }

    .wsin-page .numbered-list li {
      counter-increment: item;
      display: flex;
      align-items: flex-start;
      gap: 1.25rem;
      margin-bottom: 0.75rem;
      padding: 1.25rem 1.5rem;
      background: var(--wsin-white);
      border-radius: var(--radius-md);
      box-shadow: var(--shadow-sm);
      border: 1px solid var(--gray-200);
    }

    .wsin-page .numbered-list li::before {
      content: counter(item);
      background: var(--purple-light);
      color: white;
      width: 32px;
      height: 32px;
      min-width: 32px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 600;
      flex-shrink: 0;
      font-size: 0.9rem;
    }

    .wsin-page .numbered-list li span {
      text-align: left;
      padding-top: 0.3rem;
      color: var(--gray-700);
    }

    .wsin-page .question-card {
      background: var(--wsin-white);
      border-radius: var(--radius-lg);
      padding: 2rem;
      margin: 0 auto 1.25rem;
      box-shadow: var(--shadow-md);
      max-width: 700px;
      border: 1px solid var(--gray-200);
    }

    .wsin-page .question-card h4 {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 1rem;
      font-size: 1.1rem;
    }

    .wsin-page .question-card.q1 { border-left: 4px solid var(--purple-dark); }
    .wsin-page .question-card.q1 h4 { color: var(--purple-dark); }
    .wsin-page .question-card.q2 { border-left: 4px solid var(--purple-light); }
    .wsin-page .question-card.q2 h4 { color: var(--purple-light); }
    .wsin-page .question-card.q3 { border-left: 4px solid var(--pink); }
    .wsin-page .question-card.q3 h4 { color: var(--pink); }

    .wsin-page .question-card p, .wsin-page .question-card ul {
      max-width: none;
      text-align: left;
      margin-left: 0;
      margin-right: 0;
    }

    .wsin-page .response-list {
      list-style: none;
      padding: 0;
      margin: 1rem 0;
    }

    .wsin-page .response-list li {
      display: flex;
      align-items: stretch;
      margin-bottom: 0.75rem;
      border-radius: var(--radius-md);
      overflow: hidden;
      background: var(--wsin-white);
      border: 1px solid var(--gray-200);
    }

    .wsin-page .response-list .indicator {
      width: 48px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      font-size: 1.1rem;
      font-weight: bold;
    }

    .wsin-page .response-list .indicator.good { background: var(--teal); color: white; }
    .wsin-page .response-list .indicator.bad { background: var(--pink); color: white; }

    .wsin-page .response-list .content {
      flex: 1;
      display: flex;
      align-items: center;
      padding: 1rem 1.25rem;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .wsin-page .response-list .thought {
      font-style: italic;
      color: var(--gray-600);
      font-size: 0.95rem;
      flex: 1;
      min-width: 180px;
    }

    .wsin-page .response-list .assessment {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.85rem;
      font-weight: 600;
      padding: 0.4rem 0.75rem;
      border-radius: 20px;
      white-space: nowrap;
    }

    .wsin-page .response-list .assessment.good { background: rgba(42, 157, 143, 0.1); color: var(--teal); }
    .wsin-page .response-list .assessment.bad { background: rgba(214, 77, 106, 0.1); color: var(--pink); }
    .wsin-page .response-list .assessment svg { width: 14px; height: 14px; }

    .wsin-page .strategy-card {
      background: var(--wsin-white);
      border-radius: var(--radius-lg);
      padding: 2rem;
      margin: 0 auto 1.5rem;
      box-shadow: var(--shadow-md);
      max-width: 750px;
      border: 1px solid var(--gray-200);
      border-top-width: 3px;
    }

    .wsin-page .strategy-card.a { border-top-color: var(--purple-light); }
    .wsin-page .strategy-card.b { border-top-color: var(--pink); }
    .wsin-page .strategy-card.c { border-top-color: var(--purple-dark); }
    .wsin-page .strategy-card.d { border-top-color: var(--teal); }
    .wsin-page .strategy-card.e { border-top-color: var(--orange); }
    .wsin-page .strategy-card.f { border-top-color: var(--coral); }

    .wsin-page .strategy-header {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin-bottom: 1.25rem;
    }

    .wsin-page .strategy-letter {
      width: 44px;
      height: 44px;
      border-radius: var(--radius-sm);
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-weight: 700;
      font-size: 1.1rem;
    }

    .wsin-page .strategy-card.a .strategy-letter { background: var(--purple-light); }
    .wsin-page .strategy-card.b .strategy-letter { background: var(--pink); }
    .wsin-page .strategy-card.c .strategy-letter { background: var(--purple-dark); }
    .wsin-page .strategy-card.d .strategy-letter { background: var(--teal); }
    .wsin-page .strategy-card.e .strategy-letter { background: var(--orange); }
    .wsin-page .strategy-card.f .strategy-letter { background: var(--coral); }

    .wsin-page .strategy-card p, .wsin-page .strategy-card ul {
      max-width: none;
      text-align: left;
      margin-left: 0;
      margin-right: 0;
      color: var(--gray-700);
    }

    .wsin-page .strategy-title {
      font-weight: 600;
      font-size: 1.1rem;
      color: var(--gray-800);
    }

    .wsin-page .action-step {
      background: var(--gray-100);
      border-radius: var(--radius-md);
      padding: 1.25rem 1.5rem;
      margin-top: 1.25rem;
      font-size: 0.95rem;
      border-left: 3px solid var(--purple-light);
      display: flex;
      gap: 0.75rem;
      align-items: flex-start;
    }

    .wsin-page .action-step .action-label {
      background: var(--purple-light);
      color: white;
      font-size: 0.7rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      padding: 0.3rem 0.6rem;
      border-radius: 4px;
      flex-shrink: 0;
    }

    .wsin-page .recap-grid {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      margin: 2rem auto;
      max-width: 650px;
    }

    .wsin-page .recap-item {
      background: var(--wsin-white);
      border-radius: var(--radius-md);
      padding: 1.25rem 1.5rem;
      box-shadow: var(--shadow-sm);
      display: flex;
      align-items: center;
      gap: 1rem;
      text-align: left;
      border: 1px solid var(--gray-200);
    }

    .wsin-page .recap-item span {
      text-align: left;
      color: var(--gray-700);
    }

    .wsin-page .recap-check {
      width: 28px;
      height: 28px;
      min-width: 28px;
      background: var(--teal);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      flex-shrink: 0;
      font-size: 0.8rem;
    }

    .wsin-page .final-cta {
      background: linear-gradient(135deg, var(--purple-light) 0%, var(--purple-dark) 50%, #8b5a7c 100%);
      border-radius: var(--radius-xl);
      padding: 3.5rem;
      text-align: center;
      color: white;
      margin: 3rem auto;
      max-width: 750px;
      box-shadow: var(--shadow-xl);
    }

    .wsin-page .final-cta h3 {
      color: white;
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 1.4rem;
      margin: 0 0 1rem;
      text-transform: none;
      letter-spacing: 0;
      justify-content: center;
    }

    .wsin-page .final-cta h3::before { display: none; }

    .wsin-page .final-cta p {
      color: rgba(255,255,255,0.95);
      font-size: 1.1rem;
      max-width: 550px;
      margin: 0 auto;
      line-height: 1.7;
    }

    .wsin-page .references {
      background: var(--wsin-white);
      border-radius: var(--radius-xl);
      padding: 2.5rem;
      margin: 3rem auto 0;
      max-width: 800px;
      box-shadow: var(--shadow-md);
      border: 1px solid var(--gray-200);
    }

    .wsin-page .references h2 {
      font-size: 1.4rem;
      margin-bottom: 1.5rem;
      display: block;
    }

    .wsin-page .reference-item {
      font-size: 0.9rem;
      color: var(--gray-600);
      margin-bottom: 1rem;
      padding-left: 1.5rem;
      text-indent: -1.5rem;
      text-align: left;
      max-width: none;
      line-height: 1.6;
    }

    .wsin-page .reference-item em {
      font-style: italic;
    }

    .wsin-page .spiral-section {
      display: flex;
      flex-wrap: wrap;
      gap: 2.5rem;
      align-items: center;
      justify-content: center;
      margin: 2.5rem auto;
      max-width: 750px;
      padding: 2rem;
      background: var(--wsin-white);
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-md);
      border: 1px solid var(--gray-200);
    }

    .wsin-page .spiral-visual {
      width: 160px;
      height: 160px;
      flex-shrink: 0;
    }

    .wsin-page .spiral-visual svg { width: 100%; height: 100%; }

    .wsin-page .spiral-section > div:last-child {
      flex: 1;
      min-width: 280px;
      text-align: left;
    }

    .wsin-page .spiral-section > div:last-child p {
      max-width: none;
      margin-left: 0;
      margin-right: 0;
    }

    .wsin-page .spiral-path {
      fill: none;
      stroke: url(#spiralGradient);
      stroke-width: 6;
      stroke-linecap: round;
      stroke-dasharray: 400;
      stroke-dashoffset: 400;
      animation: drawSpiral 3s ease forwards;
    }

    @keyframes drawSpiral {
      to { stroke-dashoffset: 0; }
    }

    .wsin-page .toc {
      background: var(--wsin-white);
      border: 1px solid var(--gray-200);
      border-radius: var(--radius-lg);
      padding: 2rem;
      margin: 0 auto 3rem;
      max-width: 600px;
      box-shadow: var(--shadow-md);
    }

    .wsin-page .toc h3 {
      font-size: 0.85rem;
      color: var(--gray-500);
