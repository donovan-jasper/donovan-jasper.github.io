      <div class="cover-content">
        <h1>When Silence Isn't Neutral</h1>
        <p class="subtitle">A Student's Guide to Self-Censorship Online</p>
        <div class="cover-meta">
          <span class="cover-meta-item">
            <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
            8 min read
          </span>
