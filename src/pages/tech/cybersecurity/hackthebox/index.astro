---
import Docs from '../../../../layouts/Docs.astro';
import { techSidebar } from '../../../../data/sidebars';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Tech', href: '/tech/' },
  { label: 'Cybersecurity', href: '/tech/cybersecurity/' },
  { label: 'HackTheBox', href: '/tech/cybersecurity/hackthebox/' },
];
---

<Docs title="HackTheBox" sidebarItems={techSidebar} breadcrumbs={breadcrumbs}>
  <p class="fade-in">Here are my HackTheBox walkthroughs and analyses.</p>

  <div class="cards fade-in">
    <a href="/tech/cybersecurity/hackthebox/resource/" class="card">
      <span class="card-title">Resource</span>
      <span class="card-desc">Password-protected walkthrough.</span>
    </a>
    <a href="/tech/cybersecurity/hackthebox/compiled/" class="card">
      <span class="card-title">Compiled</span>
      <span class="card-desc">Medium difficulty Windows machine walkthrough.</span>
    </a>
  </div>
</Docs>

<style>
  .cards { display: flex; gap: 0.75rem; margin-top: 1.5rem; }
  .card { flex: 1; padding: 0.875rem 1.25rem; border-radius: 10px; border: 1px solid var(--border); background: var(--bg-card); text-decoration: none; transition: border-color 0.15s, background 0.15s; }
  .card:hover { border-color: var(--accent-border); background: var(--bg-card-hover); }
  .card-title { display: block; font-family: var(--font-heading); font-size: 0.95rem; font-weight: 600; color: var(--text-primary); margin-bottom: 0.15rem; }
  .card-desc { display: block; font-size: 0.8rem; color: var(--text-muted); }
</style>
